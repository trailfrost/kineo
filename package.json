{
  "name": "kineo-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest",
    "format": "prettier .",
    "format!": "prettier --write .",
    "lint": "eslint .",
    "check": "tsc --noEmit",
    "build": "tsc -b packages/*",
    "publish": "pnpm --cwd packages/kineo publish && pnpm --cwd packages/kineokit publish"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "eslint": "^9.32.0",
    "globals": "^16.3.0",
    "jiti": "^2.5.1",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  }
}
